{
  "db_name": "PostgreSQL",
  "query": "\n        INSERT INTO messages (id, sender_id, conversation_id, ciphertext, created_at)\n        VALUES (gen_random_uuid(), $1, $2, $3, now())\n        RETURNING \n            id, sender_id,\n            (SELECT username FROM service_users WHERE id = $1) as \"sender_username!\",\n            ciphertext, null::int as key_version,\n            created_at, edited_at, deleted\n        ",
